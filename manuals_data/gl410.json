      "body": "```html\n<!-- GL410 -->\n%@LW_pgstart@@\n<html>\n<head>\n    <title>%@LW_PField_s_prnFile@%</title>\n    <style>\n        body {\n            background-color: #fff;\n            font-family: sans-serif;\n            /**padding-bottom: 20px;**/\n            padding-left: 30px;\n            padding-top: 40px;\n            padding-right: 40px;\n            width: 1500px;\n            height:850px;\n        }\n        th{\n            color:000;\n            height: 10px;\n            white-space: nowrap;\n        }\n        th,td {\n            padding: 0 0 0 5px;\n        }\n        .isi tr:nth-child(even){\n            background-color : #d4d0ff;\n        }\n        .customers tr:hover{\n            background-color : #ddd;\n        }\n        table {\n            border-collapse:collapse;\n            font-size:12px;\n             width: 38cm; \n        }\n        .isi table, .isi td, .isi th {\n            border:1px solid black;\n        }\n        .gtot{\n            border-top: 1px solid #000;\n            border-bottom: 1px solid #000;\n            font-weight: bold;\n        }\n        .ltot,.gtot{\n            background-color: #ededed;\n        }\n        hr{\n            display: block;\n            height: 1px;\n            background: transparent;\n            width: 100%;\n            border: none;\n            border-top: solid 1px #000;\n            margin-top: 0px;\n            margin-bottom: 0px;\n        }\n        #head  table, #head td, #head th{\n            border:none !important;\n        }\n        @media print {\n            .no-print, .no-print *\n            {\n                display: none !important;\n            }\n            @page{\n                margin: 4mm 4mm 4mm 4mm;\n            }\n            .ltot,.gtot{\n                background-color: #ededed;\n            }\n            @media print{@page {size: landscape}}\n        }\n    </style>\n</head>\n<script src=\"https://code.jquery.com/jquery-1.12.4.js\"></script>\n<script src=\"https://code.jquery.com/ui/1.12.1/jquery-ui.js\"></script>\n</head>\n<body bgcolor=\"#ffffff\" text=\"#000\" style=\"font-family:arial;\">\n    LW_pgstart@%\n    %@LW_vars@prn_pglen=55;prn_yLine=10;\n    LW_vars@%\n    %@LW_prowno_0@@\n    <button class=\"no-print\" onclick=\"window.print()\">Print</button>\n    <table class=\"csvTable\">\n        <thead style=\"white-space: nowrap; padding-left: 5px;\">\n            <tr class=\"padding\">\n                <th colspan=\"13\" style=\"font-size:20px\" align=\"left\"><b>%@LW_PField_Pub_Company@%</b></th>\n                <th align=\"right\">Printed by %@LW_PField_Pub_User@% %@LW_PField_today()@% %@LW_PField_ProgNo@%</th>\n            </tr>\n            <tr height=\"50px\" valign=\"top\">\n                <th colspan=\"15\" align=\"center\" style=\"font-size: 1.5em; font-weight: bold;\">General Ledger</th>\n            </tr>\n            <tr>\n                <th align=\"left\">Period of</th>\n                <th align=\"left\" colspan=\"12\">: %@LW_PField_s_tg_f@D,D@% - %@LW_PField_s_tg_t@D,D@%</th>\n            </tr>\n            <tr>\n                <th align=\"left\">Account</th>\n                <th align=\"left\" colspan=\"12\">: %@LW_PField_s_accno_f@% - %@LW_PField_s_accno_t@%</th>\n            </tr>\n            <tr>\n                <th align=\"left\">Rct</th>\n                <th align=\"left\" colspan=\"12\">: %@LW_PField_s_Rct_f@% - %@LW_PField_s_Rct_t@%</th>\n            </tr>\n            <tr>\n                <th valign=\"bottom\" colspan=\"15\"><hr align=\"left\" style=\"margin-top:0px; margin-bottom:0px\"></th>\n            </tr>\n            <tr>\n                <th align=\"left\" valign=\"top\" colspan=\"2\">Account</th> <!-- 1-2 -->\n                <th align=\"left\" valign=\"top\" colspan=\"2\">Descr.</th> <!-- 3-4 -->\n                <th align=\"left\" valign=\"top\"></th> <!-- 5 -->\n                <th align=\"left\" valign=\"top\"></th> <!-- 6 -->\n                <th align=\"left\" valign=\"top\"></th> <!-- 7 -->\n                %@colom@c_cur = \"Y\"@\n                <th align=\"left\" valign=\"top\"></th> <!-- 8 -->\n                <th align=\"left\" valign=\"top\"> \n                <!-- 9 -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <th align=\"right\" valign=\"top\">Beginning</th> <!-- 10 -->\n                colom@%\n                <th align=\"left\" valign=\"top\"></th> <!-- 11 -->\n                <th align=\"left\" valign=\"top\"></th> <!-- 12 -->\n                %@colom@c_move = \"Y\"@\n                <th align=\"right\" valign=\"top\">Movement</th> <!-- 13 -->\n                colom@%\n                <th align=\"right\" valign=\"top\">Balance</th> <!-- 14 -->\n            </tr>\n            <tr>\n                <th align=\"left\" valign=\"top\">Cd</th> <!-- 1 -->\n                <th align=\"left\" valign=\"top\">Jrnl. No</th> <!-- 2 -->\n                <th align=\"left\" valign=\"top\">Date</th> <!-- 3 -->\n                <th align=\"left\" valign=\"top\">Item id.</th> <!-- 4 -->\n                <th align=\"left\" valign=\"top\">Name</th> <!-- 5 -->\n                <th align=\"left\" valign=\"top\" width=\"300px\">Description</th> <!-- 6 -->\n                <th align=\"left\" valign=\"top\"></th> <!-- 7 -->\n                %@colom@c_cur = \"Y\"@\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\">Amount</th> <!-- 8 -->\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\">Cur</th> <!-- 9 -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\"></th> <!-- 10 -->\n                colom@%\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\">Debit</th> <!-- 11 -->\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\">Credit</th> <!-- 12 -->\n                %@colom@c_move = \"Y\"@\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\"></th> <!-- 13 -->\n                colom@%\n                <th align=\"right\" valign=\"top\" style=\"padding-left:5px\"></th> <!-- 14 -->\n            </tr>\n            <tr>\n                <th colspan=\"15\"><hr align=\"left\" style=\"margin-top:0px; margin-bottom:0px\"></th>\n            </tr>\n        </thead>\n        LW_prowno_0@%\n        <tbody>\n            %@LW_prowno_100@@\n            <tr>\n                <td valign=\"top\" colspan=\"2\">%@LW_PField_ca_accno@%</td> <!-- 1-2 Account -->\n                <td valign=\"top\" colspan=\"2\">%@LW_PField_ca_descr@%</td> <!-- 3-4 Description -->\n                <td valign=\"top\"></td> <!-- 5 -->\n                <td valign=\"top\"></td> <!-- 6 -->\n                <td valign=\"top\"></td> <!-- 7 -->\n                %@colom@c_cur = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_normalx*s_beginx@N16/2,N,1001,1@%</td> <!-- 8 Amount-->\n                <td valign=\"top\">%@LW_PField_s_curncd@%</td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_normal*s_begin@N16/2,N,1002,1@%</td> <!-- 10 Beginning -->\n                colom@%\n                <td valign=\"top\"></td> <!-- 11 -->\n                <td valign=\"top\"></td> <!-- 12 -->\n                %@colom@c_move = \"Y\"@\n                <td align=\"right\" valign=\"top\"></td> <!-- 13 Movement -->\n                colom@%\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_normal*s_begin@N16/2,N,1003,1@%</td> <!-- 14 Balance -->\n            </tr>\n            LW_prowno_100@%\n\n            %@LW_prowno_10@@\n            <tr>\n                <td align=\"left\" valign=\"top\">%@LW_PField_gj_type@%</td> <!-- 1 Cd -->\n                <td align=\"left\" valign=\"top\">%@LW_PField_gj_batch@%</td> <!-- 2 Jml. No -->\n                <td align=\"left\" valign=\"top\">%@LW_PField_gj_date@D,D@%</td> <!-- 3 Date-->\n                <td align=\"left\" valign=\"top\">%@LW_PField_gj_itemcd+' '+gj_itemid@%</td> <!-- 4 Item id -->\n                <td align=\"left\" valign=\"top\">%@LW_PField_TableDS(cb120a,cb_name,gj_batch)@%</td> <!-- 5 Name -->\n                <td align=\"left\" valign=\"top\" style=\"white-space: nowrap;\" width=\"300px\">%@LW_PField_gj_descr@%</td> <!-- 6 Description -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 7 field -->\n                %@colom@c_cur = \"Y\".and.!empty(gj_curncd)@\n                <td align=\"right\" valign=\"top\" style=\"padding-left:5px\">%@LW_PField_gj_amtdrx-gj_amtcrx@N16/2,N,101,1@%</td> <!-- 8 Amount -->\n                <td valign=\"top\">%@LW_PField_gj_curncd@%</td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_cur = \"Y\".and.empty(gj_curncd)@\n                <td align=\"right\" valign=\"top\" style=\"padding-left:5px\"></td> <!-- 8 Amount -->\n                <td valign=\"top\"></td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <td valign=\"top\"></td> <!-- 10 -->\n                colom@%\n                <td align=\"right\" valign=\"top\" style=\"padding-left:5px\">%@LW_PField_gj_amtdr@N16/2,N,102,1@%</td> <!-- 11 Debit  -->\n                <td align=\"right\" valign=\"top\" style=\"padding-left:5px\">%@LW_PField_gj_amtcr@N16/2,N,103,1@%</td> <!-- 12 Credit -->\n                %@colom@c_move = \"Y\"@\n                <td align=\"right\" valign=\"top\" style=\"padding-left:5px\"></td> <!-- 13 -->\n                colom@%\n                <td valign=\"top\" style=\"padding-left:5px\"></td> <!-- 14 -->\n            </tr>\n            LW_prowno_10@%\n        \n            %@LW_prowno_11@@\n            %@colom@d_item = \"Y\"@\n            <tr>\n                <td align=\"left\" valign=\"top\"></td> <!-- 1 Cd -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 2 Jml. No -->\n                <td align=\"left\" valign=\"top\">%@LW_PField_gl100ano->gj_trdate@D,D@%</td> <!-- 3 Date-->\n                <td align=\"left\" valign=\"top\"></td> <!-- 4 Item id -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 5 Name -->\n                <td align=\"left\" valign=\"top\" style=\"white-space: nowrap;\" width=\"300px\">%@LW_PField_gl100ano->gj_accno +\" \"+ gj_descr@%</td> <!-- 6 Description -->\n                <td align=\"right\" valign=\"top\">%@LW_PField_gj_amtdr-gj_amtcr@N16/2,N,111,1@%</td> <!-- 7 field -->\n            colom@%\n                %@colom@c_cur = \"Y\".and.d_item = \"Y\"@\n                <td align=\"left\" valign=\"top\"></td> <!-- 8 Amount -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_begin = \"Y\".and.d_item = \"Y\"@\n                <td align=\"left\" valign=\"top\"></td> <!-- 10 -->\n                colom@%\n            %@colom@d_item = \"Y\"@\n                <td align=\"left\" valign=\"top\"></td> <!-- 11 -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 12 -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 13 -->\n                <td align=\"left\" valign=\"top\"></td> <!-- 14 -->\n            </tr>\n            colom@%\n            LW_prowno_11@%\n\n            %@LW_prowno_119@@\n            <tr class=\"ltot\">\n                <td colspan=\"5\" valign=\"top\"></td> <!-- 1-5 -->\n                <td colspan=\"2\" align=\"right\" valign=\"top\">Total Per %@LW_PField_s_accno@%: </td> <!-- 6-7 -->\n                %@colom@c_cur = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_amtdrx-s_amtcrx@N16/2,N@%</td> <!-- 8 Amount -->\n                <td valign=\"top\">%@LW_PField_s_curncd@%</td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_normal*s_begin@N16/2,N@%</td> <!-- 10 Beginning -->\n                colom@%\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_amtdr@N16/2,N@%</td> <!-- 11 Debit  -->\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_amtcr@N16/2,N@%</td> <!-- 12 Credit -->\n                %@colom@c_move = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_amtdr-s_amtcr@N16/2,N@%</td> <!-- 13 Movement -->\n                colom@%\n                <td align=\"right\" valign=\"top\"></td> <!-- 14 -->\n            </tr>\n            LW_prowno_119@%\n\n            %@LW_prowno_120@@\n            <tr>\n                <td colspan=\"7\" valign=\"top\"></td> <!-- 1-7 -->\n                %@colom@c_cur = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_normalx*(s_beginx+s_amtdrx-s_amtcrx)@N16/2,N@%</td> <!-- 8 Amount -->\n                <td valign=\"top\">%@LW_PField_s_curncd@%</td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <td align=\"right\" valign=\"top\"></td> <!-- 10 -->\n                colom@%\n                <td colspan=\"2\" align=\"right\" valign=\"top\"></td> <!-- 11-11 -->\n                %@colom@c_move = \"Y\"@\n                <td align=\"right\" valign=\"top\"></td> <!-- 13 -->\n                colom@%\n                <td align=\"right\" valign=\"top\">%@LW_PField_s_normal*(s_begin+s_amtdr-s_amtcr)@N16/2,N@%</td> <!-- 14 Balance -->\n            </tr>\n            LW_prowno_120@%\n\n            %@LW_prowno_888@@\n            <tr class=\"gtot\">\n                <td colspan=\"7\" valign=\"top\"></td> <!-- 1-7 -->\n                %@colom@c_cur = \"Y\"@\n                <td valign=\"top\"></td> <!-- 8 Amount -->\n                <td valign=\"top\"></td> <!-- 9 Cur -->\n                colom@%\n                %@colom@c_begin = \"Y\"@\n                <td align=\"right\" valign=\"top\">%@LW_PField_LR_begin@N16/2,N@%</td> <!-- 10 Beginning -->\n                colom@%\n                <td align=\"right\" valign=\"top\">%@LW_PField_LR_amtdr@N16/2,N@%</td> <!-- 11 Debit  -->\n                <td align=\"right\" valign=\"top\">%@LW_PField_LR_amtcr@N16/2,N@%</td> <!-- 12 Credit -->\n                %@colom@c_move = \"Y\"@\n                <td align=\"right\" valign=\"top\"></td> <!-- 13 Movement -->\n                colom@%\n                <td align=\"right\" valign=\"top\">%@LW_PField_LR_begin+LR_amtdr-LR_amtcr@N16/2,N@%</td> <!-- 14 Balance-->\n            </tr>\n            LW_prowno_888@%\n\n            %@LW_prowno_999@@\n            <!-- <tr valign=\"bottom\" class=\"gtot\" style=\"font-weight: bold\">\n                <td colspan=\"7\" align=\"right\">999 wow</td>\n                <td align=\"right\" style=\"padding-left:5px; border-top:1px solid black\">%@LW_PField__Gtot_1@N16/2,N@%</td>\n                <td align=\"right\" style=\"padding-left:5px; border-top:1px solid black\">%@LW_PField__Gtot_2@N16/2,N@%</td>\n                <td align=\"right\" style=\"padding-left:5px; border-top:1px solid black\">%@LW_PField__Gtot_3@N16/2,N@%</td>\n            </tr> -->\n        </tbody>\n        LW_prowno_999@%\n    </table>\n</body>\n%@LW_pgend@@\nLW_pgend@%\n</html>\n```"
