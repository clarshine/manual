      "body": "```html\n<html>\n\n  <head>\n    %@LW_pgstart@@\n    <title>PURCHASE ORDER</title>\n    <style>\n      body {\n        background-color: #fff;\n        font-family: sans-serif;\n        padding-left: 30px;\n        padding-top: 40px;\n        padding-right: 35px;\n        /*         padding-bottom: 20px; */\n        width: 840px;\n        height: 850px;\n      }\n\n      th {\n        background-color: #337ab7;\n        color: 000;\n        height: 10px;\n      }\n\n      hr {\n        display: block;\n        height: 1px;\n        background: transparent;\n        width: 100%;\n        border: none;\n        border-top: solid 1px #000;\n        margin-top: 0px;\n        margin-bottom: 0px;\n      }\n\n      .isi tr:nth-child(even) {\n        background-color: #d4d0ff;\n      }\n\n      .customers tr:hover {\n        background-color: #ddd;\n      }\n\n      table {\n        border-collapse: collapse;\n      }\n\n      .isi table,\n      .isi td,\n      .isi th {\n        border: 1px solid black;\n      }\n\n      #head table,\n      #head td,\n      #head th {\n        border: none !important;\n      }\n\n      @media print and (min-resolution: 144dpi) {\n\n        .no-print,\n        .no-print * {\n          display: none !important;\n        }\n      }\n\n    </style>\n    <style>\n      .text1 {\n        font-size: 11px;\n      }\n\n      .text2 {\n        font-size: 14px;\n      }\n\n    </style>\n  </head>\n\n  <body text=\"#000\" style=\"background-color:%LW_color_bg%\">\n\n    LW_pgstart@%\n\n    %@LW_prowno_0@@\n    <button class=\"no-print\" onclick=\"window.print()\">Print</button>\n    <table>\n      <tr>\n        <!--<td><img src=\"../..//idai/menu/logo_idai.jpeg\" width=\"70px\" height=\"70px\"></td>-->\n        <td colspan=\"4\" style=\"font-size:20px\">%@LW_PField_Pub_Company@%</td>\n        <td></td>\n        <td></td>\n        <td></td>\n      </tr>\n      <tr valign=\"top\">\n        <td width=\"360px\"></td>\n        <td></td>\n        <td colspan=\"8\" align=\"center\" style=\"font-size: 20px;\"><u border=\"1\" color=\"black\">PURCHASE ORDER</u></td>\n      </tr>\n      <tr>\n        <td></td>\n        <td></td>\n        <td colspan=\"8\" align=\"center\" style=\"font-size: 20px; \">%@LW_PField_p_noPO@%</td>\n      </tr>\n    </table>\n    <table>\n      <tr>\n        <td width=\"70px\">To</td>\n        <td>:</td>\n        <td width=\"300px\">%@LW_PField_po_Name@%</td>\n      </tr>\n      <tr>\n        <td>Attn</td>\n        <td>:</td>\n        <td>%@LW_PField_TableDS(AP010a,mp_person,po_supl)@%</td>\n      </tr>\n      <tr>\n        <td>Telp</td>\n        <td>:</td>\n        <td>%@LW_PField_TableDS(AP010a,mp_phone,po_supl)@%</td>\n        <td></td>\n\n      </tr>\n      <tr>\n        <td>Fax</td>\n        <td>:</td>\n        <td>%@LW_PField_TableDS(AP010a,mp_nofax,po_supl)@%</td>\n        <td></td>\n      </tr>\n    </table>\n    <br>\n    <table>\n      <tr>\n        <td align=\"left\" style=\"width:150px\">Dengan Hormat,</td>\n\n      </tr>\n    </table>\n    <br>\n    <table>\n      <tr>\n        <td align=\"left\" style=\"width:500px\">Dengan ini kami menunjuk perusahaan : %@LW_PField_po_Name@%</td>\n\n      </tr>\n      <tr>\n        <td align=\"left\" style=\"width:500px\">Untuk mengirimkan barang-barang dibawah ini :</td>\n\n      </tr>\n    </table>\n    <br>\n    <table width=\"100%\">\n      <tr>\n        <td colspan=\"7\">\n          <hr align=\"left\" border=\"1\" color=\"black\" style=\"margin-top:0px; margin-bottom:0px; \">\n        </td>\n      </tr>\n      <tr>\n        <td width=\"50px\" style=\"padding-right:10px;\">NO</td>\n        <td width=\"400px\" style=\"padding-right:10px;\">NAMA BARANG</td>\n        <td width=\"80px\" style=\"text-align:center;\">Truck No.</td>\n        <td width=\"70px\" style=\"text-align:right;\">QTY</td>\n        <td width=\"70px\" style=\"text-align:right;\"></td>\n        <td width=\"120px\" style=\"text-align:right;\">HARGA</td>\n        <td width=\"120px\" style=\"text-align:right;\">TOTAL</td>\n        <td></td>\n        <td></td>\n        <td></td>\n      </tr>\n      <tr>\n        <td colspan=\"7\">\n          <hr align=\"left\" color=\"black\" style=\"margin-top:0px; margin-bottom:0px\">\n        </td>\n      </tr>\n\n      LW_prowno_0@%\n    </table>\n    <table width=\"100%\">\n      %@LW_prowno_10@@\n      <tr height=\"25px\">%@LW_PRow_add@1@%\n        <td width=\"50px\" style=\"padding-right:10px;\">%@LW_PField__drow@%</td>\n        <td width=\"400px\" style=\"padding-right:10px;\">%@LW_PField_po_descr@%</td>\n        <td width=\"80px\" style=\"text-align:center;\">%@LW_PField_po_machine@%</td>\n        <td width=\"70px\" style=\"text-align:right;\">%@LW_PField_po_qty@%</td>\n        <td width=\"70px\" style=\"text-align:left;\">%@LW_PField_po_uom@%</td>\n        <td width=\"120px\" style=\"text-align:right;\">%@LW_PField_po_uprice@N,N@%</td>\n        <td width=\"120px\" style=\"text-align:right;\">%@LW_PField_po_hrg@N,N@%</td>\n      </tr>\n      LW_prowno_10@%\n    </table>\n    <table>\n      <!-- %@LW_prowno_299@@ \n        <!---->\n      <tr>\n        <td colspan=\"7\">\n          <hr align=\"left\" color=\"black\" style=\"margin-top:0px; margin-bottom:0px\">\n        </td>\n      </tr>\n\n      <tr>\n        <td colspan=\"4\"></td>\n        <td colspan=\"2\" padding=\"right\">TOTAL</td>\n        <td style=\"text-align: right;\" valign=\"top\">%@LW_PField_po_hrg@N,N@%</td>\n      </tr>\n\n      <tr>\n        <td colspan=\"4\"></td>\n        <td colspan=\"2\">DISKON</td>\n        <td style=\"text-align: right;\" valign=\"top\">%@LW_PField_po_hpot+po_hpot2@N,N@%</td>\n      </tr>\n\n      <tr>\n        <td colspan=\"4\"></td>\n        <td colspan=\"2\">PPN 10%</td>\n        <td style=\"text-align: right;\" valign=\"top\">%@LW_PField_po_htax+po_htaxL@N,N@%</td>\n      </tr>\n\n      <tr>\n        <td colspan=\"7\">\n          <hr align=\"left\" color=\"black\" style=\"margin-top:0px; margin-bottom:0px\">\n        </td>\n      </tr>\n      <tr>\n        <td colspan=\"4\"></td>\n        <td colspan=\"2\">GRAND TOTAL</td>\n        <td style=\"text-align: right;\" valign=\"top\">%@LW_PField_po_hrg-po_hpot-po_hpot2+po_htax+po_htaxL@N,N@%</td>\n      </tr>\n      <tr>\n        <td colspan=\"7\">\n          <hr align=\"left\" color=\"black\" style=\"margin-top:0px; margin-bottom:0px\">\n        </td>\n      </tr>\n    </table>\n    <table>\n      <br>\n      <tr>\n        <td align=\"left\" style=\"width:150px\">INVOICE ATAS NAMA %@LW_PField_Prn_company@%</td>\n      </tr>\n    </table>\n    <br>\n    <table>\n      <tr>\n        <td align=\"left\" style=\"width:800px\">NB : %@LW_PField_po_remark@%</td>\n      </tr>\n    </table>\n    <br>\n    <table>\n      <tr>\n        <td align=\"left\" style=\"width:500px\">Atas bantuan dan kerjasamanya, kami ucapkan terimakasih.</td>\n      </tr>\n      <tr>\n        <td align=\"left\" style=\"width:500px\">Jakarta, %@LW_PField_dvBilang(po_dtpo)@%</td>\n      </tr>\n      <tr>\n        <td align=\"left\" style=\"width:500px\">Hormat kami,</td>\n      </tr>\n    </table>\n    <br>\n    <br>\n    <br>\n    <br>\n    <br>\n    <table>\n      <tr>\n        <td align=\"left\" style=\"width:500px\"> %@LW_PField_ '( '+ATrim(GL_signer)+' )'@%</td>\n      </tr>\n    </table>\n    <!--  <table width=\"100%\">\n          <tr height=\"50px\">\n            <td colspan=\"2\" width=\"250px\">Supervisor</td>\n            <!-- <td width=\"250px\"></td>\n            <td width=\"350px\">Operasional</td>\n            <td width=\"350px\"></td>\n            <td width=\"350px\">Kasir</td>\n            <td width=\"350px\"></td>\n            <td width=\"350px\">Administrasi Doc.</td>\n            \n          </tr>\n          <tr>\n            <td width=\"250px\"></td>\n            <td width=\"350px\"></td>\n            <td width=\"350px\"></td>\n            <td width=\"250px\"></td>\n          </tr>\n          <tr height=\"50px\" valign=\"top\" >\n            <td width=\"250px\"></td>\n            \n            <td width=\"350px\"></td>\n            <td width=\"250px\"></td>\n          </tr>\n    </table>-->\n    <!-- LW_prowno_299@% -->\n  </body>\n  %@LW_pgend@@\n  LW_pgend@%\n\n</html>\n```"
